# ═══════════════════════════════════════════
# CineVault — Environment Variables
# ═══════════════════════════════════════════

# Backend
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://admin:cinevault2025@localhost:27017/cinevault?authSource=admin

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES=7d

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=cinevault-media
R2_PUBLIC_URL=https://your-r2-domain.com

# TMDB API (Optional — for movie data)
TMDB_API_KEY=dd9e1b8d8e37735e79648fd34e2979c6

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
